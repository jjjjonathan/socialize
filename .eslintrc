{
  "extends": [
    "airbnb-base",
    "next/core-web-vitals",
    "plugin:cypress/recommended",
    "prettier"
  ],
  "rules": {
    "react-hooks/exhaustive-deps": "off",
    "class-methods-use-this": "off",
    "no-underscore-dangle": "off",
    "no-console": "off",
    "react/display-name": "off",
    "jsx-a11y/alt-text": "off"
  }
}
